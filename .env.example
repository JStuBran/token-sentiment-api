# Token Sentiment Score — environment variables
# Copy this file to .env and fill in your values

# Required: Wallet address to receive x402 micropayments (USDC on Base)
WALLET_ADDRESS=0xYourWalletAddressHere

# Optional: Brave Search API key (get one at https://brave.com/search/api/)
# If not set, the /api/analyze endpoint will return a "search unavailable" note
BRAVE_SEARCH_API_KEY=your_brave_api_key_here
